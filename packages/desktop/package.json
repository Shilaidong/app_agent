{
  "name": "@terra-edu/application-agent-desktop",
  "private": true,
  "description": "Terra-Edu independent application automation Agent desktop app.",
  "version": "1.0.3",
  "type": "module",
  "license": "MIT",
  "homepage": "https://terra-edu.local/application-agent",
  "author": {
    "name": "Terra-Edu",
    "email": "hello@terra-edu.local"
  },
  "scripts": {
    "typecheck": "tsgo -b",
    "verify:application-agent": "bun ./scripts/verify-application-agent.ts",
    "verify:application-agent:e2e": "bun ./scripts/verify-application-agent-e2e.ts",
    "release:mac": "bun ./scripts/release-mac.ts",
    "release:mac:free": "bun ./scripts/release-mac.ts",
    "predev": "bun ./scripts/predev.ts",
    "dev": "electron-vite dev",
    "prebuild": "bun ./scripts/prebuild.ts",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "package": "electron-builder --config electron-builder.config.ts",
    "package:mac": "electron-builder --mac --publish never --config electron-builder.config.ts",
    "package:win": "electron-builder --win --publish never --config electron-builder.config.ts",
    "package:linux": "electron-builder --linux --publish never --config electron-builder.config.ts",
    "native:build": "bun install --cwd native"
  },
  "main": "./out/main/index.js",
  "dependencies": {
    "effect": "catalog:",
    "electron-context-menu": "4.1.2",
    "electron-log": "^5",
    "electron-store": "^10",
    "electron-updater": "^6",
    "electron-window-state": "^5.0.3",
    "drizzle-orm": "catalog:",
    "marked": "^15"
  },
  "devDependencies": {
    "@actions/artifact": "4.0.0",
    "@lydell/node-pty": "catalog:",
    "@opencode-ai/app": "workspace:*",
    "@opencode-ai/ui": "workspace:*",
    "@sentry/solid": "catalog:",
    "@sentry/vite-plugin": "catalog:",
    "@solid-primitives/i18n": "2.2.1",
    "@solid-primitives/storage": "catalog:",
    "@solidjs/meta": "catalog:",
    "@solidjs/router": "0.15.4",
    "@types/bun": "catalog:",
    "@types/node": "catalog:",
    "@typescript/native-preview": "catalog:",
    "@valibot/to-json-schema": "1.6.0",
    "electron": "41.2.1",
    "electron-builder": "^26",
    "electron-vite": "^5",
    "solid-js": "catalog:",
    "sury": "11.0.0-alpha.4",
    "typescript": "~5.6.2",
    "vite": "catalog:",
    "zod-openapi": "5.4.6"
  },
  "optionalDependencies": {
    "@lydell/node-pty-darwin-arm64": "1.2.0-beta.10",
    "@lydell/node-pty-darwin-x64": "1.2.0-beta.10",
    "@lydell/node-pty-linux-arm64": "1.2.0-beta.10",
    "@lydell/node-pty-linux-x64": "1.2.0-beta.10",
    "@lydell/node-pty-win32-arm64": "1.2.0-beta.10",
    "@lydell/node-pty-win32-x64": "1.2.0-beta.10",
    "@parcel/watcher-darwin-arm64": "2.5.1",
    "@parcel/watcher-darwin-x64": "2.5.1",
    "@parcel/watcher-linux-arm64-glibc": "2.5.1",
    "@parcel/watcher-linux-arm64-musl": "2.5.1",
    "@parcel/watcher-linux-x64-glibc": "2.5.1",
    "@parcel/watcher-linux-x64-musl": "2.5.1",
    "@parcel/watcher-win32-arm64": "2.5.1",
    "@parcel/watcher-win32-x64": "2.5.1"
  }
}
